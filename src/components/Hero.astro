---
// Hero.astro — Premium One Piece themed hero
---

<section class="relative min-h-screen flex flex-col select-none overflow-hidden bg-canvas-soft">
  <!-- Drifting mesh backdrop -->
  <div class="mesh-drift-container">
    <div class="drift-circle drift-circle-1"></div>
    <div class="drift-circle drift-circle-2"></div>
    <div class="drift-circle drift-circle-3"></div>
    <div class="drift-circle drift-circle-4"></div>
  </div>

  <!-- Nav -->
  <header class="relative z-40 w-full h-16 border-b border-hairline bg-canvas/60 backdrop-blur-md flex items-center justify-between px-6 md:px-12 shadow-vercel-sm">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-6 h-6 flex items-center justify-center">
        <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current text-accent group-hover:scale-110 transition-transform duration-300">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
      </div>
      <span class="text-xs font-semibold tracking-tight text-ink font-sans">StrawHat Studio</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="/colorise" class="text-xs text-text-secondary hover:text-ink font-medium transition-colors font-sans">Archive</a>
      <a href="#features" class="text-xs text-text-secondary hover:text-ink font-medium transition-colors font-sans">Features</a>
      <a href="#how-it-works" class="text-xs text-text-secondary hover:text-ink font-medium transition-colors font-sans">How It Works</a>
    </nav>

    <div class="flex items-center gap-3">
      <button id="theme-toggle-btn" class="w-8 h-8 rounded-full border border-hairline bg-canvas hover:bg-canvas-soft-2 flex items-center justify-center text-ink cursor-pointer transition-colors shadow-vercel-sm" aria-label="Toggle theme">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="block dark:hidden">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="hidden dark:block">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
      <a href="/colorise"
        class="px-4 py-1.5 rounded-full bg-ink hover:bg-neutral-800 text-canvas font-medium text-xs transition-all duration-150 shadow-vercel-sm uppercase tracking-wider font-mono cursor-pointer text-center hover:scale-105 active:scale-95">
        Open Archive
      </a>
    </div>
  </header>

  <!-- Hero Content -->
  <div class="relative z-10 flex-1 flex flex-col items-center justify-center px-6 pt-12 pb-8 max-w-6xl mx-auto w-full text-center">
    <div class="space-y-8 max-w-4xl mx-auto">
      <!-- Eyebrow badge -->
      <div class="flex justify-center animate-fade-up">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full badge-glass text-[10px] font-mono text-muted-readable uppercase shadow-vercel-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse-glow"></span>
          Complete One Piece Archive &middot; 1976+ Chapters
        </div>
      </div>

      <!-- Main headline -->
      <h1 class="text-5xl sm:text-7xl md:text-[84px] font-semibold tracking-[-0.04em] text-ink leading-[1.05] font-sans animate-fade-up animate-fade-up-d1">
        Bring <span class="gradient-text">One Piece</span><br />to life.
      </h1>

      <p class="text-text-secondary text-sm sm:text-base md:text-lg max-w-2xl mx-auto font-sans leading-relaxed animate-fade-up animate-fade-up-d2">
        Browse the complete Digital Colored Comics archive, download any chapter in B&W or full color, and colorize your own pages with our AI-powered engine.
      </p>

      <!-- CTA Buttons -->
      <div class="flex items-center justify-center gap-4 pt-2 animate-fade-up animate-fade-up-d3">
        <a href="/colorise"
          class="px-8 py-3.5 rounded-full bg-ink hover:bg-neutral-800 text-canvas font-semibold text-sm tracking-wider uppercase transition-all duration-150 shadow-vercel-md cursor-pointer text-center hover:scale-105 active:scale-95">
          Browse Archive
        </a>
        <a href="#hero-slider-box"
          class="px-8 py-3.5 rounded-full bg-canvas border border-hairline hover:bg-canvas-soft-2 text-ink font-semibold text-sm tracking-wider uppercase transition-all duration-150 shadow-vercel-sm hover:scale-105 active:scale-95">
          See Preview
        </a>
      </div>

      <!-- Stats row -->
      <div class="flex items-center justify-center gap-10 pt-6 animate-fade-up animate-fade-up-d4">
        <div class="text-center">
          <span class="text-2xl font-bold text-ink">1076+</span>
          <p class="text-[10px] font-mono text-muted-readable uppercase tracking-wider mt-1">Colored Chapters</p>
        </div>
        <div class="w-px h-10 bg-hairline"></div>
        <div class="text-center">
          <span class="text-2xl font-bold text-ink">900+</span>
          <p class="text-[10px] font-mono text-muted-readable uppercase tracking-wider mt-1">B&W Chapters</p>
        </div>
        <div class="w-px h-10 bg-hairline"></div>
        <div class="text-center">
          <span class="text-2xl font-bold text-ink">100%</span>
          <p class="text-[10px] font-mono text-muted-readable uppercase tracking-wider mt-1">Free Access</p>
        </div>
      </div>
    </div>

    <!-- Slider Mockup -->
    <div class="w-full max-w-4xl mt-10 animate-fade-up animate-fade-up-d5">
      <div id="hero-slider-box" class="relative w-full aspect-[16/9] md:aspect-[21/9] bg-canvas border border-hairline rounded-xl overflow-hidden shadow-vercel-lg group cursor-ew-resize">
        <!-- Colored image (right side) -->
        <img src="/manga/One-Piece-Digital-Colored-Comics/Chapter%201/Chapter%201_page-006.png"
          class="absolute inset-0 w-full h-full object-cover" alt="Colored" loading="lazy" />
        <!-- B&W image clipped by slider (left side) -->
        <div id="hero-slider-color-wrapper" class="absolute inset-0 w-full h-full overflow-hidden" style="clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);">
          <img src="/manga/One-Piece/Chapter%201/Chapter%201_page-007.png"
            class="absolute inset-0 w-full h-full object-cover" alt="Black & White" style="width: 100%; height: 100%; pointer-events: none;" loading="lazy" />
        </div>
        <!-- Handle -->
        <div id="hero-slider-handle" class="absolute top-0 bottom-0 left-1/2 w-[2px] bg-ink z-30 pointer-events-none" style="transform: translateX(-50%);">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-canvas border-2 border-ink flex items-center justify-center text-xs text-ink shadow-vercel-lg group-hover:scale-110 transition-transform duration-200">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8l4 4-4 4M6 8l-4 4 4 4"/><path d="M2 12h20"/></svg>
          </div>
        </div>
        <!-- Labels -->
        <div class="absolute bottom-3 left-3 bg-canvas/80 backdrop-blur-sm border border-hairline px-2 py-0.5 rounded text-[9px] font-mono text-text-hint z-30 uppercase tracking-wide">
          Original Lineart
        </div>
        <div class="absolute bottom-3 right-3 bg-canvas/80 backdrop-blur-sm border border-hairline px-2 py-0.5 rounded text-[9px] font-mono text-text-hint z-30 uppercase tracking-wide">
          Colorized
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="relative z-10 flex justify-center pb-6">
    <div class="w-5 h-8 rounded-full border border-hairline-strong flex justify-center pt-1.5">
      <div class="w-1 h-2 rounded-full bg-text-hint animate-bounce"></div>
    </div>
  </div>
</section>

<script>
  // Slider interaction
  let isDragging = false;
  const box = document.getElementById('hero-slider-box');
  const wrapper = document.getElementById('hero-slider-color-wrapper');
  const handle = document.getElementById('hero-slider-handle');

  function adjust(x: number) {
    if (!box || !wrapper || !handle) return;
    const rect = box.getBoundingClientRect();
    let rel = x - rect.left;
    if (rel < 0) rel = 0;
    if (rel > rect.width) rel = rect.width;
    const pct = (rel / rect.width) * 100;
    wrapper.style.clipPath = `polygon(0 0, ${pct}% 0, ${pct}% 100%, 0 100%)`;
    handle.style.left = `${pct}%`;
  }

  if (box) {
    box.addEventListener('mousedown', (e: MouseEvent) => { isDragging = true; adjust(e.clientX); });
    box.addEventListener('touchstart', (e: TouchEvent) => { isDragging = true; adjust(e.touches[0].clientX); });
  }
  window.addEventListener('mousemove', (e: MouseEvent) => { if (isDragging) adjust(e.clientX); });
  window.addEventListener('touchmove', (e: TouchEvent) => { if (isDragging) adjust(e.touches[0].clientX); });
  window.addEventListener('mouseup', () => { isDragging = false; });
  window.addEventListener('touchend', () => { isDragging = false; });

  // Theme toggle
  document.getElementById('theme-toggle-btn')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Auto-slide on load (animate once)
  setTimeout(() => {
    if (!wrapper || !handle) return;
    wrapper.style.transition = 'clip-path 2s cubic-bezier(0.16, 1, 0.3, 1)';
    handle.style.transition = 'left 2s cubic-bezier(0.16, 1, 0.3, 1)';
    wrapper.style.clipPath = 'polygon(0 0, 65% 0, 65% 100%, 0 100%)';
    handle.style.left = '65%';
    setTimeout(() => {
      wrapper.style.transition = '';
      handle.style.transition = '';
    }, 2500);
  }, 500);

  // Scroll reveal observer
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
