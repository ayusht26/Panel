---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;
---

<Layout title="Reading...">
  <main>
    <!-- Toast container for sleek mode notifications -->
    <div id="toast-container" class="fixed top-20 left-1/2 -translate-x-1/2 z-50 pointer-events-none flex flex-col gap-2 items-center"></div>

    <!-- Top toolbar/reader bar -->
    <div id="reader-bar" class="fixed top-0 right-0 left-0 z-50 flex h-14 items-center justify-between border-b border-hairline bg-canvas/80 px-3 sm:px-4 backdrop-blur-xl supports-[backdrop-filter]:bg-canvas/70 select-none transition-all duration-300">
      <!-- Left: Back & Title -->
      <div class="flex items-center gap-1.5 sm:gap-3 min-w-0">
        <a href="javascript:history.back()" class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg transition-colors hover:bg-canvas-soft text-ink" title="Back">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
        </a>

        <!-- Prev Chapter -->
        <a id="prev-chapter-btn" class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg transition-colors hover:bg-canvas-soft text-ink disabled:opacity-30 disabled:pointer-events-none" title="Previous chapter">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
          </svg>
        </a>

        <!-- Next Chapter -->
        <a id="next-chapter-btn" class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg transition-colors hover:bg-canvas-soft text-ink disabled:opacity-30 disabled:pointer-events-none" title="Next chapter">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </a>

        <div class="h-4 w-px bg-hairline shrink-0"></div>

        <span id="chapter-title" class="truncate text-xs font-semibold sm:text-sm text-ink max-w-[150px] sm:max-w-md">Loading...</span>
      </div>

      <!-- Right: Mode Badge, Mode Toggle, and Export -->
      <div class="flex items-center gap-1.5 sm:gap-2">
        <!-- Mode indicator badge -->
        <span id="mode-badge" class="hidden sm:inline-flex items-center rounded-full border border-hairline bg-canvas-soft px-2.5 py-0.5 text-[10px] font-mono text-body font-medium">
          Loading...
        </span>

        <!-- Reading Mode Toggle with animating icons -->
        <button id="mode-toggle" class="flex h-8 w-8 items-center justify-center rounded-lg transition-colors hover:bg-canvas-soft relative text-ink cursor-pointer" title="Toggle reading mode">
          <!-- Continuous (Hamburger) Icon -->
          <svg id="icon-continuous" class="absolute h-4 w-4 transition-all duration-300 transform scale-100 rotate-0 opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Continuous Strip Icon -->
          <svg id="icon-strip" class="absolute h-4 w-4 transition-all duration-300 transform scale-50 rotate-90 opacity-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3h6v18H9V3z M9 9h6 M9 15h6" />
          </svg>
          <!-- Single Page (Document) Icon -->
          <svg id="icon-single" class="absolute h-4 w-4 transition-all duration-300 transform scale-50 rotate-90 opacity-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="4" y="3" width="16" height="18" rx="2" stroke-linecap="round" stroke-linejoin="round" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 8h8M8 12h8M8 16h4" />
          </svg>
        </button>

        <!-- Export PDF button -->
        <button id="download-btn" class="flex h-8 w-8 items-center justify-center rounded-lg transition-colors hover:bg-canvas-soft text-ink cursor-pointer" title="Export PDF">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Main reader content area -->
    <div id="reader-content" class="flex min-h-screen flex-col items-center pb-24 pt-14 px-2 sm:px-4">
      <div id="pages-container" class="flex w-full flex-col items-center gap-0" data-id={id}>
        <div class="flex flex-col items-center justify-center py-48 text-center animate-fade-in">
          <div class="relative flex h-16 w-16 items-center justify-center rounded-2xl border border-hairline bg-canvas shadow-vercel-md mb-6">
            <svg class="h-8 w-8 text-ink animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h2 class="text-sm font-semibold tracking-tight text-ink">Retrieving chapter scans...</h2>
          <p class="text-xs text-mute mt-1.5 font-mono">Initializing connection to WeebCentral</p>
        </div>
      </div>
    </div>

    <!-- Unified Floating Controls Bar -->
    <div id="controls-bar" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex h-11 items-center gap-1.5 rounded-full border border-hairline bg-canvas/80 px-3 py-1 shadow-vercel-modal backdrop-blur-xl supports-[backdrop-filter]:bg-canvas/70 transition-all duration-300 select-none max-w-[95%] sm:max-w-md">
      <!-- Prev Button -->
      <button id="prev-btn" class="flex h-8 w-8 items-center justify-center rounded-full transition-colors hover:bg-canvas-soft-2 text-ink disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer" title="Previous page/scroll">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      </button>

      <!-- Page Indicator -->
      <span id="page-indicator" class="font-mono text-xs text-ink font-semibold whitespace-nowrap px-1 text-center min-w-[54px]">-- / --</span>

      <!-- Next Button -->
      <button id="next-btn" class="flex h-8 w-8 items-center justify-center rounded-full transition-colors hover:bg-canvas-soft-2 text-ink disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer" title="Next page/scroll">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      <!-- Divider -->
      <div class="h-4 w-px bg-hairline"></div>

      <!-- Zoom Out -->
      <button id="zoom-out" class="flex h-8 w-8 items-center justify-center rounded-full transition-colors hover:bg-canvas-soft-2 text-ink disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer" title="Zoom Out">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
        </svg>
      </button>

      <!-- Zoom Fit/Reset (Percentage indicator) -->
      <button id="zoom-fit" class="h-8 px-2.5 flex items-center justify-center rounded-full transition-colors hover:bg-canvas-soft-2 text-[10px] font-mono font-semibold text-mute cursor-pointer" title="Reset Zoom / Fit Page">
        100%
      </button>

      <!-- Zoom In -->
      <button id="zoom-in" class="flex h-8 w-8 items-center justify-center rounded-full transition-colors hover:bg-canvas-soft-2 text-ink disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer" title="Zoom In">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
      </button>
    </div>

    <!-- PDF compilation progress modal -->
    <div id="pdf-progress-modal" class="fixed inset-0 z-[100] hidden items-center justify-center select-none">
      <div class="absolute inset-0 bg-ink/20 backdrop-blur-sm"></div>
      <div class="relative w-full max-w-sm rounded-xl border border-hairline bg-canvas p-6 shadow-vercel-modal animate-scale-in text-center mx-4">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
          <svg class="h-6 w-6 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-sm font-semibold text-ink">Exporting PDF</h3>
        <p id="pdf-progress-text" class="mt-2 text-xs text-mute">Initializing downloader...</p>
        <div class="mt-4 h-1.5 w-full bg-canvas-soft-2 rounded-full overflow-hidden border border-hairline">
          <div id="pdf-progress-bar" class="h-full bg-ink transition-all duration-300 w-0"></div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  #pages-container {
    --zoom-factor: 1.0;
  }
  
  .page-wrapper {
    width: 100%;
    overflow-x: auto;
    text-align: center;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  
  .page-wrapper::-webkit-scrollbar {
    display: none;
  }
  
  .page-image {
    display: inline-block;
    vertical-align: middle;
    width: calc(100% * var(--zoom-factor, 1));
    max-width: calc(800px * var(--zoom-factor, 1));
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--color-hairline);
    box-shadow: var(--shadow-vercel-sm);
    transition: width 0.2s ease, max-width 0.2s ease;
    scroll-margin-top: 5rem;
  }

  .page-image-fit-height {
    max-height: calc(100vh - 120px) !important;
    width: auto !important;
    max-width: 100% !important;
    object-fit: contain !important;
  }

  #pages-container.mode-strip .page-wrapper {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  #pages-container.mode-strip .page-image {
    border-radius: 0 !important;
    border: none !important;
    box-shadow: none !important;
    margin: 0 auto !important;
    display: block !important;
  }
</style>

<script>
  const container = document.getElementById('pages-container');
  const chapterId = container?.dataset.id || '';
  const chapterTitle = document.getElementById('chapter-title');
  const pageIndicator = document.getElementById('page-indicator');
  
  const modeToggle = document.getElementById('mode-toggle');
  const modeBadge = document.getElementById('mode-badge');
  const readerBar = document.getElementById('reader-bar');
  const controlsBar = document.getElementById('controls-bar');
  
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const downloadBtn = document.getElementById('download-btn');
  const zoomInBtn = document.getElementById('zoom-in');
  const zoomOutBtn = document.getElementById('zoom-out');
  const zoomFitBtn = document.getElementById('zoom-fit');

  const prevChapterBtn = document.getElementById('prev-chapter-btn') as HTMLAnchorElement;
  const nextChapterBtn = document.getElementById('next-chapter-btn') as HTMLAnchorElement;

  let pages: string[] = [];
  let currentPage = 0;
  let activePageIdx = 0;
  let readerMode = localStorage.getItem('reader-mode') || 'long';
  if (readerMode !== 'single' && readerMode !== 'long' && readerMode !== 'strip') {
    readerMode = 'long';
  }
  let isFitHeight = localStorage.getItem('reader-fit-height') === 'true';
  let pageImages: HTMLImageElement[] = [];
  let scrollObserver: IntersectionObserver | null = null;

  // Zoom levels
  const zoomFactors = [0.6, 0.8, 1.0, 1.2, 1.4, 1.6, 1.8, 2.0];
  let zoomLevelIdx = parseInt(localStorage.getItem('reader-zoom-level') || '2', 10);
  if (zoomLevelIdx < 0 || zoomLevelIdx >= zoomFactors.length) zoomLevelIdx = 2; // Default to 1.0

  // ─── TOAST NOTIFICATION HELPERS ───
  function showToast(message: string) {
    const container = document.getElementById('toast-container');
    if (!container) return;
    
    const toast = document.createElement('div');
    toast.className = 'px-4 py-2.5 rounded-lg border border-hairline bg-canvas text-ink text-xs font-semibold font-sans shadow-vercel-modal animate-fade-up select-none pointer-events-auto flex items-center gap-2';
    toast.innerHTML = `
      <svg class="h-3.5 w-3.5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.084 1.085l-.041.02H11.25v1.5a.75.75 0 01-1.5 0v-2.25a.75.75 0 01.75-.75h.001zM12 22.5c5.799 0 10.5-4.701 10.5-10.5S17.799 1.5 12 1.5 1.5 6.201 1.5 12 6.201 22.5 12 22.5z" />
      </svg>
      <span>${message}</span>
    `;
    
    container.appendChild(toast);
    
    setTimeout(() => {
      toast.classList.add('opacity-0', 'transition-opacity', 'duration-300');
      setTimeout(() => {
        toast.remove();
      }, 300);
    }, 2000);
  }

  // ─── ZOOM CONTROLS ───
  function applyZoom() {
    const factor = zoomFactors[zoomLevelIdx];
    if (container) {
      container.style.setProperty('--zoom-factor', String(factor));
    }
    
    pageImages.forEach(img => {
      if (img) {
        if (readerMode === 'single' && isFitHeight && factor === 1.0) {
          img.classList.add('page-image-fit-height');
        } else {
          img.classList.remove('page-image-fit-height');
        }
      }
    });

    if (zoomFitBtn) {
      if (readerMode === 'single' && isFitHeight && factor === 1.0) {
        zoomFitBtn.textContent = 'Fit H';
      } else {
        zoomFitBtn.textContent = `${Math.round(factor * 100)}%`;
      }
    }
    
    if (zoomInBtn) (zoomInBtn as HTMLButtonElement).disabled = zoomLevelIdx === zoomFactors.length - 1;
    if (zoomOutBtn) (zoomOutBtn as HTMLButtonElement).disabled = zoomLevelIdx === 0;
    
    localStorage.setItem('reader-zoom-level', String(zoomLevelIdx));
  }

  function toggleFitHeight() {
    if (readerMode !== 'single') return;
    isFitHeight = !isFitHeight;
    localStorage.setItem('reader-fit-height', String(isFitHeight));
    applyZoom();
    showToast(isFitHeight ? 'Fitted to page height' : 'Fitted to page width');
  }

  // ─── OBSERVER FOR SCROLL TRACKING ───
  function initScrollObserver() {
    if (scrollObserver) scrollObserver.disconnect();
    
    scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const index = parseInt(entry.target.getAttribute('data-index') || '0', 10);
          activePageIdx = index;
          if (readerMode !== 'single') {
            if (pageIndicator) pageIndicator.textContent = `${activePageIdx + 1} / ${pages.length}`;
            updateNextPrevBtnStates();
          }
        }
      });
    }, {
      root: null,
      rootMargin: '-30% 0px -40% 0px',
      threshold: 0
    });

    pageImages.forEach(img => {
      if (img) scrollObserver.observe(img);
    });
  }

  // ─── NAV AND RENDER UPDATES ───
  function updatePage() {
    if (pages.length === 0) return;

    applyZoom();

    // Set container class for strip mode
    if (container) {
      if (readerMode === 'strip') {
        container.classList.add('mode-strip');
      } else {
        container.classList.remove('mode-strip');
      }
    }

    // Update Mode text badge
    if (modeBadge) {
      if (readerMode === 'single') {
        modeBadge.textContent = 'Single Page';
      } else if (readerMode === 'strip') {
        modeBadge.textContent = 'Continuous Strip';
      } else {
        modeBadge.textContent = 'Continuous Scroll';
      }
    }

    // Toggle icons for mode toggle button
    const iconContinuous = document.getElementById('icon-continuous');
    const iconStrip = document.getElementById('icon-strip');
    const iconSingle = document.getElementById('icon-single');
    if (iconContinuous && iconStrip && iconSingle) {
      if (readerMode === 'single') {
        iconContinuous.classList.remove('scale-100', 'opacity-100', 'rotate-0');
        iconContinuous.classList.add('scale-50', 'opacity-0', 'rotate-90');
        
        iconStrip.classList.remove('scale-100', 'opacity-100', 'rotate-0');
        iconStrip.classList.add('scale-50', 'opacity-0', 'rotate-90');

        iconSingle.classList.remove('scale-50', 'opacity-0', '-rotate-90', 'rotate-90');
        iconSingle.classList.add('scale-100', 'opacity-100', 'rotate-0');
      } else if (readerMode === 'strip') {
        iconContinuous.classList.remove('scale-100', 'opacity-100', 'rotate-0');
        iconContinuous.classList.add('scale-50', 'opacity-0', 'rotate-90');
        
        iconSingle.classList.remove('scale-100', 'opacity-100', 'rotate-0');
        iconSingle.classList.add('scale-50', 'opacity-0', 'rotate-90');

        iconStrip.classList.remove('scale-50', 'opacity-0', '-rotate-90', 'rotate-90');
        iconStrip.classList.add('scale-100', 'opacity-100', 'rotate-0');
      } else { // 'long'
        iconStrip.classList.remove('scale-100', 'opacity-100', 'rotate-0');
        iconStrip.classList.add('scale-50', 'opacity-0', 'rotate-90');

        iconSingle.classList.remove('scale-100', 'opacity-100', 'rotate-0');
        iconSingle.classList.add('scale-50', 'opacity-0', '-rotate-90', 'rotate-90');

        iconContinuous.classList.remove('scale-50', 'opacity-0', 'rotate-90');
        iconContinuous.classList.add('scale-100', 'opacity-100', 'rotate-0');
      }
    }

    if (readerMode === 'single') {
      pageImages.forEach((img, i) => {
        const wrapper = img.parentElement;
        if (wrapper) {
          wrapper.style.display = i === currentPage ? 'block' : 'none';
        }
      });
      
      if (scrollObserver) {
        scrollObserver.disconnect();
        scrollObserver = null;
      }
      
      if (pageIndicator) pageIndicator.textContent = `${currentPage + 1} / ${pages.length}`;
      updateNextPrevBtnStates();
    } else {
      pageImages.forEach(img => {
        const wrapper = img.parentElement;
        if (wrapper) {
          wrapper.style.display = 'block';
        }
      });
      
      initScrollObserver();
      if (pageIndicator) pageIndicator.textContent = `${activePageIdx + 1} / ${pages.length}`;
      updateNextPrevBtnStates();
    }
  }

  function updateNextPrevBtnStates() {
    const hasPrev = readerMode === 'single' ? currentPage > 0 : activePageIdx > 0;
    const hasNext = readerMode === 'single' ? currentPage < pages.length - 1 : activePageIdx < pages.length - 1;

    if (prevBtn) {
      (prevBtn as HTMLButtonElement).disabled = !hasPrev;
    }
    if (nextBtn) {
      (nextBtn as HTMLButtonElement).disabled = !hasNext;
    }
  }

  function setMode(mode: 'single' | 'long' | 'strip') {
    readerMode = mode;
    localStorage.setItem('reader-mode', mode);
    
    if (mode !== 'single') {
      activePageIdx = currentPage;
      updatePage();
      setTimeout(() => {
        pageImages[activePageIdx]?.scrollIntoView({ behavior: 'instant', block: 'start' });
      }, 50);
    } else {
      currentPage = activePageIdx;
      updatePage();
      window.scrollTo({ top: 0, behavior: 'instant' });
    }
    
    let modeText = 'Continuous Scroll';
    if (mode === 'single') modeText = 'Single Page';
    if (mode === 'strip') modeText = 'Continuous Strip';
    showToast(`Switched to ${modeText}`);
  }

  function goToPrev() {
    if (readerMode === 'single') {
      if (currentPage > 0) {
        currentPage--;
        updatePage();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    } else {
      if (activePageIdx > 0) {
        activePageIdx--;
        pageImages[activePageIdx]?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }

  // Go to next item
  function goToNext() {
    if (readerMode === 'single') {
      if (currentPage < pages.length - 1) {
        currentPage++;
        updatePage();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    } else {
      if (activePageIdx < pages.length - 1) {
        activePageIdx++;
        pageImages[activePageIdx]?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }

  // ─── LOAD CHAPTER AND SETUP ELEMENTS ───
  async function loadChapter() {
    try {
      const res = await fetch(`/api/chapter/${chapterId}`);
      if (!res.ok) throw new Error('Failed to load');
      const data = await res.json();
      pages = data.pages || [];
      if (chapterTitle) {
        chapterTitle.textContent = data.chapterTitle || `Chapter`;
      }
      document.title = `Reading - ${data.chapterTitle || 'Chapter'}`;

      if (prevChapterBtn && nextChapterBtn) {
        const seriesId = data.seriesId;
        if (seriesId) {
          try {
            let stored = sessionStorage.getItem('ch-seq-' + seriesId);
            if (!stored) {
              const resSeries = await fetch(`/api/series/${seriesId}?includeChapters=all`);
              if (resSeries.ok) {
                const seriesData = await resSeries.json();
                const allCh = seriesData.chapters || [];
                stored = JSON.stringify(allCh.map((c: any) => c.id));
                sessionStorage.setItem('ch-seq-' + seriesId, stored);
              }
            }
            if (stored) {
              const seq: string[] = JSON.parse(stored);
              const idx = seq.indexOf(chapterId);
              if (idx !== -1) {
                if (idx < seq.length - 1) {
                  prevChapterBtn.href = `/read/${seq[idx + 1]}`;
                  prevChapterBtn.classList.remove('opacity-30', 'pointer-events-none');
                } else {
                  prevChapterBtn.removeAttribute('href');
                  prevChapterBtn.classList.add('opacity-30', 'pointer-events-none');
                }
                if (idx > 0) {
                  nextChapterBtn.href = `/read/${seq[idx - 1]}`;
                  nextChapterBtn.classList.remove('opacity-30', 'pointer-events-none');
                } else {
                  nextChapterBtn.removeAttribute('href');
                  nextChapterBtn.classList.add('opacity-30', 'pointer-events-none');
                }
              } else {
                prevChapterBtn.removeAttribute('href');
                nextChapterBtn.removeAttribute('href');
                prevChapterBtn.classList.add('opacity-30', 'pointer-events-none');
                nextChapterBtn.classList.add('opacity-30', 'pointer-events-none');
              }
            } else {
              prevChapterBtn.removeAttribute('href');
              nextChapterBtn.removeAttribute('href');
              prevChapterBtn.classList.add('opacity-30', 'pointer-events-none');
              nextChapterBtn.classList.add('opacity-30', 'pointer-events-none');
            }
          } catch (err) {
            console.error('Failed to resolve chapter sequence:', err);
            prevChapterBtn.removeAttribute('href');
            nextChapterBtn.removeAttribute('href');
            prevChapterBtn.classList.add('opacity-30', 'pointer-events-none');
            nextChapterBtn.classList.add('opacity-30', 'pointer-events-none');
          }
        }
      }

      if (pages.length === 0) {
        if (container) {
          container.innerHTML = `<div class="flex flex-col items-center gap-3 py-20 text-center"><p class="text-sm text-mute">No pages found</p></div>`;
        }
        return;
      }

      if (container) {
        container.innerHTML = '';
      }
      pageImages = [];

      pages.forEach((url, i) => {
        const wrapper = document.createElement('div');
        wrapper.className = 'page-wrapper select-none my-1';
        
        const img = document.createElement('img');
        img.src = url;
        img.alt = `Page ${i + 1}`;
        img.className = 'page-image';
        img.loading = i < 2 ? 'eager' : 'lazy';
        img.setAttribute('data-index', String(i));
        
        wrapper.appendChild(img);
        if (container) {
          container.appendChild(wrapper);
        }
        pageImages.push(img);

        img.onerror = () => {
          wrapper.innerHTML = `
            <div class="m-2 flex aspect-[3/4] w-full max-w-[800px] items-center justify-center rounded-lg border border-hairline bg-canvas-soft-2 mx-auto">
              <p class="text-xs text-mute">Page ${i + 1} failed to load</p>
            </div>
          `;
        };
      });

      updatePage();

      // Keyboard bindings
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === ' ') {
          e.preventDefault();
          goToNext();
        }
        if (e.key === 'ArrowLeft') {
          goToPrev();
        }
        if (e.key === 'a' && prevChapterBtn && prevChapterBtn.href) {
          e.preventDefault();
          window.location.href = prevChapterBtn.href;
        }
        if (e.key === 'd' && nextChapterBtn && nextChapterBtn.href) {
          e.preventDefault();
          window.location.href = nextChapterBtn.href;
        }
      });

    } catch {
      if (container) {
        container.innerHTML = `
          <div class="flex flex-col items-center gap-4 py-20 text-center">
            <p class="text-lg font-medium">Failed to load chapter</p>
            <p class="text-sm text-mute">The chapter may not exist or WeebCentral is unavailable.</p>
            <a href="/" class="mt-2 inline-flex h-10 items-center rounded-full bg-ink px-5 text-sm font-medium text-canvas">Go home</a>
          </div>
        `;
      }
    }
  }

  // ─── TOOLBAR AUTO-HIDE ON SCROLL ───
  let lastScrollY = window.scrollY;
  window.addEventListener('scroll', () => {
    if (readerMode === 'single') return; // Always keep visible in single page mode
    
    const currentScrollY = window.scrollY;
    if (Math.abs(currentScrollY - lastScrollY) < 12) return;
    
    if (currentScrollY > lastScrollY && currentScrollY > 120) {
      // Scrolling down - hide toolbars
      readerBar?.classList.add('-translate-y-16', 'opacity-0', 'pointer-events-none');
      controlsBar?.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
    } else {
      // Scrolling up - show toolbars
      readerBar?.classList.remove('-translate-y-16', 'opacity-0', 'pointer-events-none');
      controlsBar?.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
    }
    lastScrollY = currentScrollY;
  });

  // Toggle toolbars on backdrop/image clicks
  document.getElementById('reader-content')?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('button') || (e.target as HTMLElement).closest('a')) {
      return;
    }
    
    const isHidden = readerBar?.classList.contains('-translate-y-16');
    if (isHidden) {
      readerBar?.classList.remove('-translate-y-16', 'opacity-0', 'pointer-events-none');
      controlsBar?.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
    } else {
      readerBar?.classList.add('-translate-y-16', 'opacity-0', 'pointer-events-none');
      controlsBar?.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
    }
  });

  // ─── ZOOM LISTENERS ───
  zoomInBtn?.addEventListener('click', () => {
    if (zoomLevelIdx < zoomFactors.length - 1) {
      zoomLevelIdx++;
      applyZoom();
    }
  });

  zoomOutBtn?.addEventListener('click', () => {
    if (zoomLevelIdx > 0) {
      zoomLevelIdx--;
      applyZoom();
    }
  });

  zoomFitBtn?.addEventListener('click', () => {
    if (readerMode === 'single') {
      if (zoomLevelIdx !== 2) {
        zoomLevelIdx = 2; // Reset to 1.0 (Fit Width)
        applyZoom();
      } else {
        toggleFitHeight(); // Toggle Fit Height
      }
    } else {
      zoomLevelIdx = 2; // Reset zoom to 1.0 (Fit Width)
      applyZoom();
    }
  });

  // ─── NAV CLICK LISTENERS ───
  prevBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    goToPrev();
  });
  
  nextBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    goToNext();
  });

  modeToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (readerMode === 'long') {
      setMode('strip');
    } else if (readerMode === 'strip') {
      setMode('single');
    } else {
      setMode('long');
    }
  });

  // ─── PDF COMPILATION ENGINE ───
  async function loadAndConvertImage(url: string): Promise<{ dataUrl: string; width: number; height: number }> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => {
        try {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          const ctx = canvas.getContext('2d');
          if (!ctx) {
            reject(new Error('Canvas context could not be created'));
            return;
          }
          ctx.drawImage(img, 0, 0);
          const dataUrl = canvas.toDataURL('image/jpeg', 0.92);
          resolve({
            dataUrl,
            width: img.naturalWidth,
            height: img.naturalHeight
          });
        } catch (e) {
          reject(e);
        }
      };
      img.onerror = () => reject(new Error('Image fetch failed'));
      img.src = url;
    });
  }

  async function loadAndConvertImageWithRetry(url: string, retries = 3): Promise<{ dataUrl: string; width: number; height: number }> {
    for (let attempt = 1; attempt <= retries; attempt++) {
      try {
        return await loadAndConvertImage(url);
      } catch (err) {
        if (attempt === retries) throw err;
        console.warn(`Download retry ${attempt}/${retries} failed for ${url}. Re-trying in 1s...`);
        await new Promise(r => setTimeout(r, 1000));
      }
    }
    throw new Error(`Max retries reached for image: ${url}`);
  }

  downloadBtn?.addEventListener('click', async (e) => {
    e.stopPropagation();
    if (pages.length === 0) return;
    
    const progressModal = document.getElementById('pdf-progress-modal');
    const progressText = document.getElementById('pdf-progress-text');
    const progressBar = document.getElementById('pdf-progress-bar');
    
    if (progressModal) {
      progressModal.classList.remove('hidden');
      progressModal.classList.add('flex');
    }

    try {
      if (!(window as any).jspdf) {
        if (progressText) progressText.textContent = 'Loading PDF Engine...';
        await new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }

      interface LoadedImageData {
        dataUrl?: string;
        width: number;
        height: number;
        isPlaceholder?: boolean;
        pageNum?: number;
      }

      const loadedImages: LoadedImageData[] = [];
      const totalPages = pages.length;

      for (let i = 0; i < totalPages; i++) {
        if (progressText) progressText.textContent = `Downloading Page ${i + 1} / ${totalPages}...`;
        if (progressBar) progressBar.style.width = `${((i) / totalPages) * 100}%`;

        const originalUrl = pages[i];
        const proxiedUrl = `/api/proxy-image?url=${encodeURIComponent(originalUrl)}`;
        
        try {
          const imgData = await loadAndConvertImageWithRetry(proxiedUrl, 3);
          loadedImages.push(imgData);
        } catch (err) {
          console.error(`Page ${i + 1} export failed:`, err);
          loadedImages.push({
            isPlaceholder: true,
            width: 800,
            height: 1200,
            pageNum: i + 1
          });
        }
      }

      if (progressText) progressText.textContent = 'Compiling PDF pages...';
      if (progressBar) progressBar.style.width = '95%';

      const { jsPDF } = (window as any).jspdf;
      const firstPage = loadedImages[0];
      const pdf = new jsPDF({
        orientation: firstPage.width > firstPage.height ? 'landscape' : 'portrait',
        unit: 'px',
        format: [firstPage.width, firstPage.height]
      });

      loadedImages.forEach((imgData, i) => {
        if (i > 0) {
          pdf.addPage([imgData.width, imgData.height], imgData.width > imgData.height ? 'l' : 'p');
        }
        
        if (imgData.isPlaceholder) {
          pdf.setFillColor(245, 245, 245);
          pdf.rect(0, 0, imgData.width, imgData.height, 'F');
          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(24);
          pdf.setTextColor(150, 150, 150);
          pdf.text(`Page ${imgData.pageNum} failed to load`, imgData.width / 2, imgData.height / 2, { align: 'center' });
        } else if (imgData.dataUrl) {
          pdf.addImage(imgData.dataUrl, 'JPEG', 0, 0, imgData.width, imgData.height);
        }
      });

      const title = chapterTitle?.textContent || 'manga-chapter';
      const cleanFileName = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'chapter';
      
      if (progressText) progressText.textContent = 'Saving PDF document...';
      if (progressBar) progressBar.style.width = '100%';
      
      pdf.save(`${cleanFileName}.pdf`);
      showToast('Exported PDF successfully!');

      setTimeout(() => {
        if (progressModal) {
          progressModal.classList.add('hidden');
          progressModal.classList.remove('flex');
        }
      }, 800);

    } catch (err) {
      console.error('PDF compiling error:', err);
      if (progressText) progressText.textContent = 'Export compilation failed!';
      showToast('Export failed. Downloading current page...');
      
      try {
        const link = document.createElement('a');
        const activeIdx = readerMode === 'single' ? currentPage : activePageIdx;
        link.download = `${chapterId}-page-${activeIdx + 1}.png`;
        link.href = pages[activeIdx];
        link.click();
      } catch {
        const activeIdx = readerMode === 'single' ? currentPage : activePageIdx;
        window.open(pages[activeIdx], '_blank');
      }

      setTimeout(() => {
        if (progressModal) {
          progressModal.classList.add('hidden');
          progressModal.classList.remove('flex');
        }
      }, 2000);
    }
  });

  loadChapter();
</script>
