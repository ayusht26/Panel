---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const { id } = Astro.params;
---

<Layout title="Loading...">
  <Nav />
  <main class="page-enter mx-auto max-w-7xl px-6 pb-24 pt-4 sm:pt-8 flex-1 w-full">
    <div id="series-detail" class="w-full" data-id={id}>
      <!-- Detailed Pulsing Layout Skeleton -->
      <div class="grid gap-10 md:grid-cols-[300px_1fr] items-start animate-pulse">
        <!-- Cover Skeleton -->
        <div class="flex flex-col gap-4">
          <div class="mx-auto w-full max-w-[240px] md:max-w-none aspect-[3/4] rounded-xl border border-hairline bg-canvas-soft-2 skeleton"></div>
          <div class="h-4 w-28 bg-canvas-soft-2 rounded mx-auto skeleton"></div>
          <div class="h-3 w-16 bg-canvas-soft-2 rounded mx-auto skeleton"></div>
        </div>

        <!-- Info Skeleton -->
        <div class="space-y-4">
          <div class="h-8 w-3/4 bg-canvas-soft-2 rounded skeleton"></div>
          <div class="h-4 w-1/3 bg-canvas-soft-2 rounded skeleton"></div>
          
          <div class="flex gap-2">
            <div class="h-6 w-16 bg-canvas-soft-2 rounded-full skeleton"></div>
            <div class="h-6 w-20 bg-canvas-soft-2 rounded-full skeleton"></div>
            <div class="h-6 w-14 bg-canvas-soft-2 rounded-full skeleton"></div>
          </div>
          
          <div class="h-32 w-full bg-canvas-soft-2 rounded-xl mt-6 skeleton"></div>
          
          <div class="space-y-3 mt-10">
            <div class="h-6 w-28 bg-canvas-soft-2 rounded skeleton"></div>
            <div class="h-10 w-full bg-canvas-soft-2 rounded-xl skeleton"></div>
            <div class="h-40 w-full bg-canvas-soft-2 rounded-xl skeleton"></div>
          </div>
        </div>
      </div>
    </div>

  </main>

  <!-- Lightbox Modal for Cover Image Expansion -->
  <div id="lightbox-modal" class="fixed inset-0 z-[150] hidden items-center justify-center bg-black/45 dark:bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300 select-none">
    <div id="lightbox-card" class="relative max-h-[85vh] max-w-[90vw] md:max-w-[480px] w-full rounded-2xl border border-hairline bg-canvas shadow-vercel-modal flex flex-col overflow-hidden theme-transition transform origin-center">
      <!-- Header -->
      <div class="flex items-center justify-between border-b border-hairline px-4 py-3 bg-canvas-soft">
        <div class="flex flex-col">
          <span class="text-[10px] font-mono uppercase tracking-wider text-mute">Cover Art</span>
          <span id="lightbox-title" class="text-sm font-semibold text-ink leading-tight truncate max-w-[240px]">Series Title</span>
        </div>
        <button id="lightbox-close" class="flex h-8 w-8 items-center justify-center rounded-full border border-hairline bg-canvas text-ink hover:bg-canvas-soft-2 transition-all cursor-pointer shadow-vercel-sm" aria-label="Close lightbox">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Image Content Container -->
      <div class="relative flex-grow bg-canvas-soft-2 p-4 flex items-center justify-center overflow-hidden aspect-[3/4]">
        <img id="lightbox-img" src="" alt="Full Cover" class="h-full w-full object-contain rounded-lg shadow-vercel-md select-none pointer-events-none" />
      </div>

      <!-- Footer -->
      <div class="flex items-center justify-between border-t border-hairline px-4 py-3 bg-canvas-soft">
        <span id="lightbox-meta" class="text-[11px] font-mono text-mute">Dimensions: ~</span>
        <button id="lightbox-download" class="inline-flex h-8 items-center justify-center rounded-full bg-ink px-4 text-xs font-medium text-canvas hover:opacity-90 transition-all cursor-pointer shadow-vercel-sm">
          Open Original
        </button>
      </div>
    </div>
  </div>
  <Footer />
</Layout>

<script>
  const container = document.getElementById('series-detail');
  const seriesId = container?.dataset.id || '';
  const lightbox = document.getElementById('lightbox-modal');
  const lightboxCard = document.getElementById('lightbox-card');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxMeta = document.getElementById('lightbox-meta');
  const lightboxDownload = document.getElementById('lightbox-download');

  let isTransitioning = false;

  function openLightbox(imgSrc: string, title: string) {
    if (isTransitioning || !lightbox || !lightboxCard || !lightboxImg) return;

    isTransitioning = true;
    
    // Set content details
    if (lightboxTitle) lightboxTitle.textContent = title;
    lightboxImg.src = imgSrc;

    // Estimate file metadata / dimensions once image loads
    if (lightboxMeta) lightboxMeta.textContent = "Format: JPEG";
    lightboxImg.onload = () => {
      if (lightboxMeta) {
        lightboxMeta.textContent = `${lightboxImg.naturalWidth} × ${lightboxImg.naturalHeight}`;
      }
    };

    // Calculate "First" position
    const coverContainer = document.getElementById('cover-container');
    const firstRect = coverContainer ? coverContainer.getBoundingClientRect() : null;

    // Show lightbox container, disable transitions initially to position instantly
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';

    // Force style recalculation / layout
    const lastRect = lightboxCard.getBoundingClientRect();

    if (firstRect) {
      // "Invert" - transform lightbox card so it matches position and scale of original cover container
      const deltaX = (firstRect.left + firstRect.width / 2) - (lastRect.left + lastRect.width / 2);
      const deltaY = (firstRect.top + firstRect.height / 2) - (lastRect.top + lastRect.height / 2);
      const scaleX = firstRect.width / lastRect.width;
      const scaleY = firstRect.height / lastRect.height;

      lightboxCard.style.transition = 'none';
      lightboxCard.style.transform = `translate(${deltaX}px, ${deltaY}px) scale(${scaleX}, ${scaleY})`;
      lightbox.classList.add('opacity-0');
    }

    // Force layout / reflow
    lightboxCard.offsetHeight;

    // "Play" - transition back to center normal layout
    requestAnimationFrame(() => {
      lightbox.classList.remove('opacity-0');
      lightboxCard.style.transition = 'transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1)';
      lightboxCard.style.transform = 'none';
      
      setTimeout(() => {
        isTransitioning = false;
      }, 450);
    });
  }

  function closeLightbox() {
    if (isTransitioning || !lightbox || !lightboxCard) return;

    isTransitioning = true;

    const coverContainer = document.getElementById('cover-container');
    const targetRect = coverContainer ? coverContainer.getBoundingClientRect() : null;
    const currentRect = lightboxCard.getBoundingClientRect();

    if (targetRect) {
      const deltaX = (targetRect.left + targetRect.width / 2) - (currentRect.left + currentRect.width / 2);
      const deltaY = (targetRect.top + targetRect.height / 2) - (currentRect.top + currentRect.height / 2);
      const scaleX = targetRect.width / currentRect.width;
      const scaleY = targetRect.height / currentRect.height;

      lightbox.classList.add('opacity-0');
      lightboxCard.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
      lightboxCard.style.transform = `translate(${deltaX}px, ${deltaY}px) scale(${scaleX}, ${scaleY})`;
    } else {
      lightbox.classList.add('opacity-0');
    }

    document.body.style.overflow = '';

    setTimeout(() => {
      lightbox.classList.remove('flex');
      lightbox.classList.add('hidden');
      lightboxCard.style.transform = '';
      lightboxCard.style.transition = '';
      isTransitioning = false;
    }, 400);
  }

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || (e.target as HTMLElement).closest('#lightbox-close')) {
      closeLightbox();
    }
  });

  lightboxDownload?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (lightboxImg.src) {
      window.open(lightboxImg.src, '_blank');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  async function loadSeries() {
    try {
      // Fetch metadata only for snappy load
      const res = await fetch(`/api/series/${seriesId}`);
      if (!res.ok) throw new Error('Not found');
      const s = await res.json();
      document.title = s.title;

      const tags = (s.tags || []).slice(0, 5);

      // Determine skeletal placeholder state synchronously based on local history
      const history = JSON.parse(localStorage.getItem('manga-reading-history') || '[]');
      const seriesHistory = history.find((h: any) => h.seriesId === seriesId);
      
      const skeletonsHtml = seriesHistory ? `
        <div class="h-10 w-40 rounded-full bg-canvas-soft-2 border border-hairline skeleton shadow-vercel-sm animate-fade-up"></div>
        <div class="h-10 w-28 rounded-full bg-canvas-soft-2 border border-hairline skeleton shadow-vercel-sm animate-fade-up-d1"></div>
        <div class="h-10 w-28 rounded-full bg-canvas-soft-2 border border-hairline skeleton shadow-vercel-sm animate-fade-up-d2"></div>
      ` : `
        <div class="h-10 w-28 rounded-full bg-canvas-soft-2 border border-hairline skeleton shadow-vercel-sm animate-fade-up"></div>
        <div class="h-10 w-28 rounded-full bg-canvas-soft-2 border border-hairline skeleton shadow-vercel-sm animate-fade-up-d1"></div>
      `;

      if (container) {
        container.innerHTML = `
          <div class="grid gap-10 md:grid-cols-[300px_1fr] items-start">
            <!-- Cover -->
            <div class="flex flex-col gap-4">
              <div id="cover-container" class="mx-auto w-full max-w-[240px] md:max-w-none aspect-[3/4] overflow-hidden rounded-xl border border-hairline bg-canvas-soft-2 shadow-vercel-md cursor-pointer hover:opacity-90 transition-all duration-300">
                <img src="${s.image}" alt="${s.title}" class="h-full w-full object-contain" />
              </div>
              ${s.year ? `<span class="text-xs font-mono text-mute text-center">${s.year} ${s.status ? `· ${s.status}` : ''}</span>` : ''}
              ${s.type ? `<span class="text-xs text-mute text-center">${s.type}</span>` : ''}
            </div>

            <!-- Info -->
            <div>
              <h1 class="text-3xl font-semibold tracking-[-0.03em]">${s.title}</h1>

              ${s.altTitles && s.altTitles.length > 0 ? `
                <p class="mt-1 text-sm text-mute">${s.altTitles.slice(0, 3).join(' · ')}</p>
              ` : ''}

              ${tags.length > 0 ? `
                <div class="mt-4 flex flex-wrap gap-2">
                  ${tags.map(t => `<span class="rounded-full border border-hairline bg-canvas-soft px-3 py-1 text-[11px] text-body">${t}</span>`).join('')}
                </div>
              ` : ''}

              <!-- Quick Action CTAs row -->
              <div id="quick-actions" class="mt-6 flex flex-wrap gap-3">
                ${skeletonsHtml}
              </div>

              ${s.authors && s.authors.length > 0 ? `
                <p class="mt-6 text-sm text-body">
                  <span class="font-medium text-ink">Author${s.authors.length > 1 ? 's' : ''}:</span> ${s.authors.join(', ')}
                </p>
              ` : ''}

              ${s.description ? `
                <div class="mt-5 rounded-xl border border-hairline bg-canvas-soft p-5">
                  <p class="text-sm leading-relaxed text-body">${s.description}</p>
                </div>
              ` : ''}

              <!-- Chapters -->
              <div class="mt-10">
                <h2 class="mb-4 text-lg font-semibold tracking-[-0.02em]">
                  <span id="chapters-heading">Chapters</span>
                </h2>

                <div id="chapters-placeholder" class="flex flex-col items-center justify-center gap-3 rounded-xl border border-hairline bg-canvas-soft py-12">
                  <svg class="h-8 w-8 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                  </svg>
                  <p id="chapters-placeholder-text" class="text-sm text-mute">Chapter list not loaded</p>
                  <button id="load-chapters-btn" class="inline-flex h-9 items-center gap-2 rounded-full bg-ink px-4 text-xs font-medium text-canvas transition-all hover:opacity-90 cursor-pointer">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
                    </svg>
                    Load chapters
                  </button>
                  <div id="chapters-loading" class="hidden">
                    <div class="mx-auto h-5 w-5 animate-spin rounded-full border-2 border-hairline-strong border-t-ink"></div>
                    <p class="mt-2 text-xs text-mute font-mono">Fetching chapter list...</p>
                  </div>
                </div>

                <div id="chapters-ui" class="hidden">
                  <div class="mb-4 flex gap-2">
                    <div class="relative flex-1">
                      <input
                        id="chapter-search"
                        type="text"
                        placeholder="Search chapters..."
                        class="w-full h-10 px-4 rounded-xl border border-hairline bg-canvas text-sm text-ink placeholder:text-mute focus:outline-none focus:ring-1 focus:ring-ink"
                      />
                    </div>
                    <button id="chapter-sort" class="inline-flex h-10 items-center gap-2 px-4 rounded-xl border border-hairline bg-canvas text-xs font-semibold text-ink hover:bg-canvas-soft transition-all shadow-vercel-sm cursor-pointer" data-sort="desc" title="Toggle sorting order">
                      <svg id="sort-icon-desc" class="h-3.5 w-3.5 text-mute transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5h14.25M3 9h9.75M3 13.5h5.25m5.25-.75L17.25 9m0 0L21 12.75M17.25 9v12" />
                      </svg>
                      <svg id="sort-icon-asc" class="h-3.5 w-3.5 text-mute transition-transform duration-300 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5h14.25M3 9h9.75M3 13.5h5.25m9.75-1.5L17.25 21m0 0L13.5 17.25M17.25 21V9" />
                      </svg>
                      <span id="sort-text">Newest</span>
                    </button>
                  </div>
                  <div id="chapters-list" class="divide-y divide-hairline rounded-xl border border-hairline bg-canvas max-h-[600px] overflow-y-auto">
                    <!-- Chapters rendered dynamically -->
                  </div>
                </div>
              </div>
            </div>
          </div>
        `;
      }

      // Hook up cover click event to open lightbox
      const coverContainer = document.getElementById('cover-container');
      coverContainer?.addEventListener('click', () => {
        openLightbox(s.image, s.title);
      });

      // Hook up manual chapters loading button click
      const loadBtn = document.getElementById('load-chapters-btn');
      const chaptersPlaceholder = document.getElementById('chapters-placeholder');
      const chaptersUi = document.getElementById('chapters-ui');
      const chaptersLoading = document.getElementById('chapters-loading');
      const chaptersHeading = document.getElementById('chapters-heading');

      loadBtn?.addEventListener('click', async () => {
        loadBtn.classList.add('hidden');
        chaptersLoading?.classList.remove('hidden');
        try {
          await fetchChapters();
          chaptersPlaceholder?.classList.add('hidden');
          chaptersUi?.classList.remove('hidden');
          if (chaptersHeading) {
            chaptersHeading.textContent = `Chapters (${allChapters.length})`;
          }
          chaptersContainer = document.getElementById('chapters-list');
          
          // Setup search filter & sort once list is visible
          const searchInput = document.getElementById('chapter-search');
          searchInput?.addEventListener('input', (e) => {
            currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
            renderChapters();
          });

          const sortBtn = document.getElementById('chapter-sort');
          const sortText = document.getElementById('sort-text');
          const sortIconDesc = document.getElementById('sort-icon-desc');
          const sortIconAsc = document.getElementById('sort-icon-asc');

          sortBtn?.addEventListener('click', () => {
            if (currentSort === 'desc') {
              currentSort = 'asc';
              if (sortText) sortText.textContent = 'Oldest';
              sortIconDesc?.classList.add('hidden');
              sortIconAsc?.classList.remove('hidden');
            } else {
              currentSort = 'desc';
              if (sortText) sortText.textContent = 'Newest';
              sortIconDesc?.classList.remove('hidden');
              sortIconAsc?.classList.add('hidden');
            }
            renderChapters();
          });

          // Listen to checkbox tick button clicks
          chaptersContainer?.addEventListener('click', (e) => {
            const tickBtn = (e.target as HTMLElement).closest('.tick-btn');
            if (tickBtn) {
              e.preventDefault();
              e.stopPropagation();
              const chId = tickBtn.getAttribute('data-id');
              if (chId) {
                toggleChapterRead(chId);
              }
            }
          });

          renderChapters();
        } catch (err) {
          loadBtn.classList.remove('hidden');
          chaptersLoading?.classList.add('hidden');
          const p = document.getElementById('chapters-placeholder-text');
          if (p) p.textContent = 'Failed to load chapters. Try again.';
        }
      });

      // Start background fetch for chapters list and action buttons
      fetchChapters().catch(() => {});

    } catch (err) {
      console.error('Failed to load series details:', err);
      if (container) {
        container.innerHTML = `
          <div class="flex flex-col items-center gap-4 py-20 text-center">
            <p class="text-lg font-medium">Series not found</p>
            <p class="text-sm text-mute">The series may not exist or WeebCentral is unavailable.</p>
            <a href="/" class="mt-2 inline-flex h-10 items-center rounded-full bg-ink px-5 text-sm font-medium text-canvas">Go home</a>
          </div>
        `;
      }
    }
  }

  // Chapter variables
  let currentSort = 'desc';
  let currentSearch = '';
  let allChapters: any[] = [];
  let chaptersContainer: HTMLElement | null = null;
  let fetchPromise: Promise<any> | null = null;

  async function fetchChapters() {
    if (fetchPromise) return fetchPromise;

    fetchPromise = fetch(`/api/series/${seriesId}?includeChapters=all`)
      .then(res => {
        if (!res.ok) throw new Error('Failed');
        return res.json();
      })
      .then(data => {
        allChapters = data.chapters || [];
        sessionStorage.setItem('ch-seq-' + seriesId, JSON.stringify(allChapters.map((c: any) => c.id)));
        updateActionButtons();
        return allChapters;
      })
      .catch(err => {
        fetchPromise = null;
        throw err;
      });

    return fetchPromise;
  }

  function updateActionButtons() {
    const quickActions = document.getElementById('quick-actions');
    if (!quickActions || allChapters.length === 0) return;

    // Check if there is history for this series
    const history = JSON.parse(localStorage.getItem('manga-reading-history') || '[]');
    const seriesHistory = history.find((h: any) => h.seriesId === seriesId);

    let continueBtnHtml = '';
    let startBtnClass = '';
    let latestBtnClass = '';

    if (seriesHistory) {
      // Find next chapter to read
      const lastReadId = seriesHistory.lastChapterId;
      const idx = allChapters.findIndex((c: any) => c.id === lastReadId);
      
      let nextChId = lastReadId;
      let nextChTitle = seriesHistory.lastChapterTitle;
      let isLatestRead = false;

      if (idx !== -1) {
        if (idx > 0) {
          nextChId = allChapters[idx - 1].id;
          nextChTitle = allChapters[idx - 1].title || `Chapter ${allChapters[idx - 1].chapter}`;
        } else {
          isLatestRead = true;
        }
      }

      continueBtnHtml = `
        <a href="/read/${nextChId}" class="inline-flex h-10 items-center justify-center gap-2 rounded-full bg-ink px-6 text-xs font-semibold text-canvas transition-all hover:opacity-90 active:scale-[0.97] cursor-pointer shadow-vercel-sm animate-fade-up">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
          </svg>
          ${isLatestRead ? `Re-read Latest (${nextChTitle})` : `Continue: ${nextChTitle}`}
        </a>
      `;

      startBtnClass = 'inline-flex h-10 items-center justify-center gap-2 rounded-full border border-hairline bg-canvas px-6 text-xs font-semibold text-ink transition-all hover:bg-canvas-soft active:scale-[0.97] cursor-pointer shadow-vercel-sm animate-fade-up-d1';
      latestBtnClass = 'inline-flex h-10 items-center justify-center gap-2 rounded-full border border-hairline bg-canvas px-6 text-xs font-semibold text-ink transition-all hover:bg-canvas-soft active:scale-[0.97] cursor-pointer shadow-vercel-sm animate-fade-up-d2';
    } else {
      startBtnClass = 'inline-flex h-10 items-center justify-center gap-2 rounded-full bg-ink px-6 text-xs font-semibold text-canvas transition-all hover:opacity-90 active:scale-[0.97] cursor-pointer shadow-vercel-sm animate-fade-up';
      latestBtnClass = 'inline-flex h-10 items-center justify-center gap-2 rounded-full border border-hairline bg-canvas px-6 text-xs font-semibold text-ink transition-all hover:bg-canvas-soft active:scale-[0.97] cursor-pointer shadow-vercel-sm animate-fade-up-d1';
    }

    const startCh = allChapters[allChapters.length - 1];
    const latestCh = allChapters[0];

    quickActions.innerHTML = `
      ${continueBtnHtml}
      <a href="/read/${startCh.id}" class="${startBtnClass}">
        Read from Start
      </a>
      <a href="/read/${latestCh.id}" class="${latestBtnClass}">
        Latest Chapter
      </a>
    `;
  }

  function renderChapters() {
    if (!chaptersContainer || !allChapters) return;

    // Filter chapters
    let filtered = allChapters.filter(ch => {
      const title = (ch.title || 'Chapter ' + ch.chapter).toLowerCase();
      return title.includes(currentSearch);
    });

    // Sort chapters
    let displayList = [...filtered];
    if (currentSort === 'asc') {
      displayList.reverse();
    }

    const readKey = 'read-ch-' + seriesId;
    const readList = JSON.parse(localStorage.getItem(readKey) || '[]');

    // Generate items HTML with checkmarks
    const itemsHtml = displayList.map(ch => {
      const originalIdx = allChapters.findIndex(c => c.id === ch.id);
      const displayNum = allChapters.length - originalIdx;
      const isRead = readList.includes(ch.id);
      
      return `
        <a href="/read/${ch.id}" class="chapter-item flex items-center justify-between px-4 py-3 text-sm transition-all duration-300 hover:bg-canvas-soft opacity-0 translate-y-2" data-id="${ch.id}">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-canvas-soft-2 text-[11px] font-mono text-mute">${displayNum}</span>
            <span class="font-medium text-ink ${isRead ? 'text-body/65' : ''}">${ch.title || 'Chapter ' + ch.chapter}</span>
          </div>
          <div class="flex items-center gap-3">
            ${ch.date ? `<span class="text-xs text-mute font-mono">${new Date(ch.date).toLocaleDateString()}</span>` : ''}
            
            <button class="tick-btn flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-hairline bg-canvas shadow-vercel-sm transition-all hover:bg-canvas-soft-2 cursor-pointer" data-id="${ch.id}" title="${isRead ? 'Mark as unread' : 'Mark as read'}">
              ${isRead ? `
                <svg class="h-3.5 w-3.5 text-success fill-success animate-scale-in" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
              ` : `
                <svg class="h-3.5 w-3.5 text-mute opacity-45 hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              `}
            </button>
          </div>
        </a>
      `;
    }).join('');

    if (displayList.length === 0) {
      chaptersContainer.innerHTML = `
        <div class="flex items-center justify-center py-12">
          <p class="text-sm text-mute">No chapters match your search</p>
        </div>
      `;
      return;
    }

    chaptersContainer.style.opacity = '0';
    chaptersContainer.style.transform = 'translateY(4px)';
    chaptersContainer.style.transition = 'opacity 0.15s ease, transform 0.15s ease';

    setTimeout(() => {
      if (chaptersContainer) {
        chaptersContainer.innerHTML = itemsHtml;
        chaptersContainer.style.opacity = '1';
        chaptersContainer.style.transform = 'translateY(0)';

        const items = chaptersContainer.querySelectorAll('.chapter-item');
        items.forEach((item, index) => {
          setTimeout(() => {
            item.classList.remove('opacity-0', 'translate-y-2');
            item.classList.add('opacity-100', 'translate-y-0');
          }, Math.min(index * 15, 300));
        });
      }
    }, 150);
  }

  function toggleChapterRead(chId: string) {
    const readKey = 'read-ch-' + seriesId;
    let readList = JSON.parse(localStorage.getItem(readKey) || '[]');
    if (readList.includes(chId)) {
      readList = readList.filter((id: string) => id !== chId);
    } else {
      readList.push(chId);
    }
    localStorage.setItem(readKey, JSON.stringify(readList));
    
    renderChapters();
    updateActionButtons();
  }

  loadSeries();
</script>
